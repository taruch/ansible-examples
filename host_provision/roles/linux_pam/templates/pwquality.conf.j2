# /etc/security/pwquality.conf
# Managed by Ansible — do not edit manually

# Minimum acceptable password length
minlen = {{ linux_pam_pwquality_minlen }}

# Character class credits (negative = minimum required, positive = maximum credit)
dcredit = {{ linux_pam_pwquality_dcredit }}
ucredit = {{ linux_pam_pwquality_ucredit }}
lcredit = {{ linux_pam_pwquality_lcredit }}
ocredit = {{ linux_pam_pwquality_ocredit }}

# Minimum number of character classes required
minclass = {{ linux_pam_pwquality_minclass }}

# Maximum consecutive identical characters
maxrepeat = {{ linux_pam_pwquality_maxrepeat }}

# Number of retries before returning error to the application
retry = {{ linux_pam_pwquality_retry }}

{% if linux_pam_pwquality_enforce_for_root %}
# Enforce policy when root sets a password
enforce_for_root
{% endif %}
